# Copy this file to `.env` in the project root and fill in real values.
# Never commit `.env` -- it is already listed in .gitignore.
#
#   cp .env.example .env
#
# Each variable below lists which script(s) read it.

# Required by:
#   src/generation/generate_with_openrouter.py
#   src/evaluation/evaluate_with_llm.py       (the LLM judge runs via OpenRouter)
#   src/tools/check_openrouter_limit.py
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Required by:
#   src/generation/generate_with_gemini.py
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
